# Supabase API (Obligatorias)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...your-anon-key...

# Supabase Service Role Key (Para operaciones Admin seguras desde el servidor)
SUPABASE_SERVICE_ROLE_KEY=eyJh...your-service-key...

# Configuración de Correo SMTP (Gmail App Passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tu-tienda@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Configuración de Pago QR Corporativo
NEXT_PUBLIC_CORPORATE_QR_URL=https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?auto=format&fit=crop&w=600&q=80
NEXT_PUBLIC_BANK_NAME=Banco de Crédito (BCP) / Banco Ganadero
NEXT_PUBLIC_BANK_ACCOUNT=100-2345678-90
NEXT_PUBLIC_BANK_HOLDER=UPCYCLING LAB S.R.L.
